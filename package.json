{
  "name": "qwen-ai-service",
  "version": "1.0.0",
  "description": "Multi-protocol AI service based on llama.cpp with Tools and MCP support",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "jest",
    "test:unit": "jest test/unit",
    "test:integration": "jest test/integration",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "pm2:start": "pm2 start ecosystem.config.js",
    "pm2:stop": "pm2 stop ecosystem.config.js",
    "pm2:restart": "pm2 restart ecosystem.config.js",
    "pm2:logs": "pm2 logs qwen-ai-service",
    "pm2:monit": "pm2 monit"
  },
  "keywords": [
    "llama.cpp",
    "ai",
    "openai",
    "anthropic",
    "mcp",
    "tools"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.17.1",
    "@fastify/cors": "^8.5.0",
    "@fastify/websocket": "^10.0.1",
    "axios": "^1.6.5",
    "fastify": "^4.25.2",
    "js-yaml": "^4.1.0",
    "jsonschema": "^1.4.1",
    "openai": "^4.25.0",
    "p-queue": "^8.0.1",
    "sharp": "^0.34.5",
    "winston": "^3.11.0",
    "winston-daily-rotate-file": "^4.7.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/jest": "^29.5.11",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.11.5",
    "@typescript-eslint/eslint-plugin": "^6.19.1",
    "@typescript-eslint/parser": "^6.19.1",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "node-addon-api": "^8.0.0",
    "node-gyp": "^10.0.0",
    "pm2": "^5.3.0",
    "prettier": "^3.2.4",
    "ts-jest": "^29.1.2",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
