# ============================================
# Qwen AI Service - Docker Environment
# ============================================
# 使用说明：
# 1. 复制此文件为 .env
# 2. 根据需要修改配置
# 3. 运行 docker-compose up -d

# ---------- 服务配置 ----------
NODE_ENV=production
SERVICE_HOST=0.0.0.0
SERVICE_PORT=8000

# ---------- 模型路径 ----------
# 相对路径或绝对路径都可以
# Windows: D:\\LLM Model\\Qwen-3.5\\models\\gguf
# Linux: ./models
MODELS_PATH=./models

# ---------- 默认模型 ----------
LLAMA_MODEL=Qwen3.5-9B-Q4_K_M.gguf

# ---------- llama.cpp 配置 ----------
LLAMA_CTX_SIZE=8192
LLAMA_THREADS=4
LLAMA_GPU_LAYERS=35

# ---------- 日志配置 ----------
LOG_LEVEL=info
LOG_CONSOLE=true

# ---------- 端口映射 ----------
# AI 服务外部端口（可自定义）
HOST_PORT=8000
# llama.cpp 外部端口（仅调试用，生产环境可注释）
LLAMA_PORT=8001
